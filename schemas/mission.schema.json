{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aiworkos.academy/schemas/mission.schema.json",
  "title": "MissionDefinition",
  "type": "object",
  "required": [
    "mission_id",
    "version",
    "role_track",
    "title",
    "difficulty",
    "estimated_minutes",
    "learning_objectives",
    "workspace_context",
    "steps",
    "events",
    "deliverables",
    "rubric",
    "pass_rules"
  ],
  "properties": {
    "mission_id": { "type": "string", "pattern": "^[a-z0-9_\\-]+$" },
    "version": { "type": "string" },
    "role_track": { "type": "string" },
    "title": { "type": "string" },
    "difficulty": { "type": "string", "enum": ["beginner", "intermediate", "advanced"] },
    "estimated_minutes": { "type": "integer", "minimum": 5, "maximum": 180 },
    "learning_objectives": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "workspace_context": {
      "type": "object",
      "required": ["company", "user_role", "timezone", "data_sources"],
      "properties": {
        "company": { "type": "string" },
        "user_role": { "type": "string" },
        "timezone": { "type": "string" },
        "language": { "type": "string", "default": "en" },
        "data_sources": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["source_id", "type", "label", "payload_ref"],
            "properties": {
              "source_id": { "type": "string" },
              "type": { "type": "string", "enum": ["email", "meeting", "doc", "sheet", "chat", "task"] },
              "label": { "type": "string" },
              "payload_ref": { "type": "string" }
            }
          }
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["step_id", "name", "goal", "required_actions"],
        "properties": {
          "step_id": { "type": "string" },
          "name": { "type": "string" },
          "goal": { "type": "string" },
          "recommended_agent": { "type": "string" },
          "required_actions": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["open_source", "summarize", "extract_actions", "prioritize", "draft_email", "draft_memo", "draft_plan", "validate_claims", "delegate_agent", "finalize_bundle"]
            }
          },
          "completion_check": {
            "type": "object",
            "properties": {
              "must_produce_artifacts": { "type": "array", "items": { "type": "string" } },
              "min_quality_score": { "type": "integer", "minimum": 0, "maximum": 100 }
            }
          }
        }
      }
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["event_id", "trigger", "effect"],
        "properties": {
          "event_id": { "type": "string" },
          "trigger": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": { "type": "string", "enum": ["time_elapsed", "step_completed", "score_below", "manual"] },
              "value": { "type": ["string", "integer", "number"] }
            }
          },
          "effect": {
            "type": "object",
            "required": ["type", "payload_ref"],
            "properties": {
              "type": { "type": "string", "enum": ["inject_email", "inject_chat", "change_deadline", "new_risk"] },
              "payload_ref": { "type": "string" }
            }
          }
        }
      }
    },
    "deliverables": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["deliverable_id", "type", "title", "required_sections"],
        "properties": {
          "deliverable_id": { "type": "string" },
          "type": { "type": "string", "enum": ["email", "memo", "brief", "task_table", "plan", "slide_outline"] },
          "title": { "type": "string" },
          "required_sections": { "type": "array", "items": { "type": "string" } },
          "max_words": { "type": "integer", "minimum": 30, "maximum": 3000 }
        }
      }
    },
    "rubric": {
      "type": "object",
      "required": ["weights", "criteria"],
      "properties": {
        "weights": {
          "type": "object",
          "required": ["outcome", "decision_quality", "communication", "risk", "efficiency", "automation_readiness"],
          "properties": {
            "outcome": { "type": "number" },
            "decision_quality": { "type": "number" },
            "communication": { "type": "number" },
            "risk": { "type": "number" },
            "efficiency": { "type": "number" },
            "automation_readiness": { "type": "number" }
          }
        },
        "criteria": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["criterion_id", "description", "scoring_guide"],
            "properties": {
              "criterion_id": { "type": "string" },
              "description": { "type": "string" },
              "scoring_guide": { "type": "string" }
            }
          }
        }
      }
    },
    "pass_rules": {
      "type": "object",
      "required": ["min_total_score", "must_complete_deliverables"],
      "properties": {
        "min_total_score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "must_complete_deliverables": { "type": "boolean" },
        "max_attempts_for_mastery_badge": { "type": "integer", "minimum": 1, "maximum": 20 }
      }
    }
  }
}
